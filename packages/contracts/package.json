{
  "name": "@codex-skin/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared Zod schemas / types for palette, doctor slices, control-plane errors (ADR 0004). Dev-plane only — not shipped inside versions/<id>.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node --test dist/index.test.js"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "@types/node": "^22.16.5"
  },
  "engines": {
    "node": ">=20"
  }
}
